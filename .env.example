# Groq API Key for AI features (chat, analyze, fix, import, layout, translate, etc.)
# Get one at https://console.groq.com/keys
# IMPORTANT: Rotate this key if it has ever been committed to version control.
GROQ_API_KEY=gsk_your_api_key_here

# Google OAuth Client ID for sign-in (optional — app works without it)
PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Custom signaling server URL for collaboration (optional — defaults to wss://signaling.yjs.dev)
PUBLIC_SIGNALING_URL=wss://your-signaling-server.example.com

# Allowed origins for the signaling server CORS (comma-separated, used by server.js)
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
